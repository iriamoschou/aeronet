# AeroNetB Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

SECRET_KEY=change-this-to-a-random-string-in-production

# PostgreSQL — local
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/aeronetb

# MongoDB Atlas — replace with your connection string from Atlas dashboard
MONGO_URI=mongodb+srv://aeronetb_user:YOURPASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=aeronetb

PORT=5000
